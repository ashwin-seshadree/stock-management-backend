# General settings
PORT=3200
NODE_ENV=development # development, uat, production

# mysql settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=stock_management

# jwt config
JWT_SECRET=
JWT_EXPIRATION=1h
JWT_ISSUER=jarvis
JWT_ALGORITHM= # HS256, HS384, HS512 # Note: Ensure to set JWT_ALGORITHM to a valid value for authentication.